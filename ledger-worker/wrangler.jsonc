{
  // Config for the standalone Worker that hosts the NymLedger Durable Object
  "name": "nym-ledger",
  "main": "index.js",
  "compatibility_date": "2024-09-23",
  "durable_objects": {
    "bindings": [{ "name": "NYM_LEDGER", "class_name": "NymLedger" }]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["NymLedger"] }
  ],
  "r2_buckets": [
    { "binding": "R2_BUCKET", "bucket_name": "nymbot" }
  ]
}
